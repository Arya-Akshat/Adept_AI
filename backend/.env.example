# === Server Configuration ===
NODE_ENV=development
PORT=4004

# === Frontend Origins ===
# CORS origins for WebSocket connections and API calls
APP_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# === Database Settings ===
# Connection string to MongoDB Atlas or local MongoDB
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/vedaai

# === Security / JWT Credentials ===
# Secret keys for signing access and refresh tokens
JWT_SECRET=your_jwt_access_secret_key
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key

# === Paths ===
# Absolute paths to constants/rawData and constants/processedData folders
RAW_DATA_PATH=./src/constants/rawData
PROCESSED_DATA_PATH=./src/constants/processedData

# === Python FastAPI Engine Integration ===
FASTAPI_URL=http://localhost:5001

# === Legacy Google Gemini Integration (Roadmaps/PDFs) ===
GEMINI_API_KEY=your_google_gemini_api_key

# === Groq Text Generation AI Configuration ===
# Primary text generator provider for assessments
GROQ_API_KEY=your_groq_api_key_here

# === Background Queues (BullMQ / Redis) ===
# Connection URL for Redis server
REDIS_URL=redis://localhost:6379

# Concurrency for BullMQ Worker (number of concurrent jobs)
WORKER_CONCURRENCY=3
ROADMAP_WORKER_CONCURRENCY=3
VECTOR_WORKER_CONCURRENCY=2

# Max character limit for extracted source materials (to avoid token overflow)
MAX_SOURCE_CONTENT_CHARS=3000

# === Qdrant Vector DB Settings ===
QDRANT_URL=https://xxxx.aws.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here
